generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model News {
  id          String   @id @default(cuid())
  title       String
  excerpt     String
  content     String
  category    String
  image       String
  author      String
  publishedAt DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([category])
  @@index([publishedAt])
}

model Blog {
  id          String   @id @default(cuid())
  title       String
  excerpt     String
  content     String
  category    String
  image       String
  author      String
  publishedAt DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([category])
  @@index([publishedAt])
}

model Event {
  id          String   @id @default(cuid())
  title       String
  description String
  date        DateTime
  time        String
  location    String
  image       String
  category    String
  registrationLink String?
  isStaple    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([date])
  @@index([category])
}

model GalleryImage {
  id          String   @id @default(cuid())
  title       String
  description String?
  imageUrl    String
  category    String
  uploadedAt  DateTime @default(now())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([category])
  @@index([uploadedAt])
}

model Member {
  id        String   @id @default(cuid())
  firstName String
  lastName  String
  email     String   @unique
  phone     String?
  year      String
  major     String
  interests String?
  joinedAt  DateTime @default(now())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
  @@index([joinedAt])
}

model Contact {
  id          String   @id @default(cuid())
  companyName String
  contactName String
  email       String
  phone       String?
  diligenceType String  @default("organization") // "organization", "new-hire"
  description String
  createdAt   DateTime @default(now())
  read        Boolean  @default(false)

  @@index([createdAt])
  @@index([read])
  @@index([diligenceType])
}

model Newsletter {
  id        String   @id @default(cuid())
  email     String   @unique
  createdAt DateTime @default(now())

  @@index([email])
  @@index([createdAt])
}

model LeadershipTeam {
  id          String   @id @default(cuid())
  name        String
  position    String
  role        String
  imageUrl    String?
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([order])
}

// DueSphere Content Management Models
model Service {
  id          String   @id @default(cuid())
  title       String
  description String
  icon        String   // Icon name or emoji
  features    String[] // Array of feature descriptions
  deliverables String[] // Array of deliverable descriptions
  isActive    Boolean  @default(true)
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@index([isActive])
  @@index([order])
}

// DueSphere User System Model
model User {
  id              String   @id @default(cuid())
  clerkId         String   @unique
  email           String   @unique
  name            String?
  role            String   @default("client") // "admin" or "client"
  companyName     String?
  companySize     String?
  subscriptionTier String  @default("free") // "free", "pro", "enterprise"
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  dueDiligenceRequests DueDiligenceRequest[]
  notifications       Notification[]

  @@index([clerkId])
  @@index([role])
}

// DueSphere Due Diligence System Models
model DueDiligenceRequest {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title           String
  description     String
  diligenceType   String   // "organization" | "new-hire"
  status          String   @default("pending") // "pending", "document-review", "background-check", "stakeholder", "analysis", "completed", "cancelled"
  priority        String   @default("medium")
  organizationName String?
  kraPin          String?
  businessPermit  String?
  cr12IssueDate   DateTime?
  directorCount   Int?
  budget          Float?
  phase           Int      @default(1) // 1-5 per proposal
  requestedDate   DateTime @default(now())
  startDate       DateTime?
  completedDate   DateTime?
  documents       Json[]   @default([])
  riskRating      String?  // "low", "medium", "high" (final)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  diligenceReport DueDiligenceReport?
  findings        DueDiligenceFinding[]
  documentUploads DueDiligenceDocument[]

  @@index([userId])
  @@index([status])
  @@index([diligenceType])
  @@index([requestedDate])
}

model DueDiligenceReport {
  id                    String   @id @default(cuid())
  dueDiligenceRequestId String   @unique
  dueDiligenceRequest   DueDiligenceRequest @relation(fields: [dueDiligenceRequestId], references: [id], onDelete: Cascade)
  executiveSummary      String?
  legalCompliance       String?
  governance            String?
  sanctionsScreening    String?
  reputationalRisk      String?
  recommendations       String[]
  riskRating            String?  // "low", "medium", "high"
  generatedAt           DateTime @default(now())
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([dueDiligenceRequestId])
}

model DueDiligenceFinding {
  id              String   @id @default(cuid())
  dueDiligenceRequestId String
  dueDiligenceRequest   DueDiligenceRequest @relation(fields: [dueDiligenceRequestId], references: [id], onDelete: Cascade)
  title           String
  description     String
  riskLevel       String   // "low", "medium", "high"
  category        String   // "legal", "governance", "financial", "reputation", "sanctions"
  evidence        String?
  recommendation  String?
  status          String   @default("open") // "open", "mitigated", "accepted"
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([dueDiligenceRequestId])
  @@index([riskLevel])
  @@index([status])
}

model DueDiligenceDocument {
  id              String   @id @default(cuid())
  dueDiligenceRequestId String
  dueDiligenceRequest   DueDiligenceRequest @relation(fields: [dueDiligenceRequestId], references: [id], onDelete: Cascade)
  filename        String
  documentType    String   // "KRA_PIN", "Business_Permit", "CR12", "ID_Passport", etc.
  fileUrl         String
  verified        Boolean  @default(false)
  notes           String?
  uploadedAt      DateTime @default(now())

  @@index([dueDiligenceRequestId])
  @@index([documentType])
}

model Notification {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type            String   // "due_diligence_created", "due_diligence_updated", "report_ready", "finding_created"
  title           String
  message         String
  read            Boolean  @default(false)
  dueDiligenceRequestId String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([userId])
  @@index([read])
  @@index([createdAt])
}
